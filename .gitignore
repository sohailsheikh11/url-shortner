# =========================
# Node modules (both frontend + backend)
# =========================
node_modules/
**/node_modules/

# =========================
# Environment variables (VERY IMPORTANT)
# =========================
.env
.env.*
frontend/.env
backend/.env

# =========================
# Logs
# =========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =========================
# Build outputs
# =========================
frontend/build/
frontend/dist/
backend/dist/
dist/
build/

# =========================
# OS files
# =========================
.DS_Store
Thumbs.db

# =========================
# IDE / Editor files
# =========================
.vscode/
.idea/
*.swp

# =========================
# Cache
# =========================
.cache/
.parcel-cache/

# =========================
# Testing / coverage
# =========================
coverage/

# =========================
# Temporary files
# =========================
tmp/
temp/
*.local

# =========================
# Optional (if using Vite/Next)
# =========================
frontend/.vite/
frontend/.next/

# =========================
# Lock files (optional choice)
# =========================
# Uncomment if you don't want them (generally keep them)
# package-lock.json
# yarn.lock